<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.xingzhewa.ccgui</id>
    <name>CC Assistant</name>
    <vendor>xingzhe-wa</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow
            factoryClass="com.github.xingzhewa.ccgui.toolWindow.MyToolWindowFactory"
            id="CCGUI"
            key="tool.window.name"
            icon="META-INF/icons/ccgui_logo_13x13.png"/>

        <!-- Project Services -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.bridge.BridgeManager"/>

        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.config.CCGuiConfig"/>

        <!-- SDK Services (Phase 2.5) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.adaptation.sdk.ClaudeCodeClient"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.adaptation.sdk.SdkSessionManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.adaptation.sdk.SdkPermissionHandler"/>

        <!-- Core Services (Phase 3) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.orchestrator.ChatOrchestrator"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.context.ContextManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.session.SessionManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.streaming.StreamingOutputEngine"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.config.ConfigManager"/>

        <!-- Feature Services (Phase 4) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.interaction.InteractiveRequestEngine"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.prompt.PromptOptimizer"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.multimodal.MultimodalInputHandler"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.task.TaskProgressTracker"/>

        <!-- Ecosystem Services (Phase 5) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.skill.SkillsManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.skill.SkillExecutor"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.agent.AgentsManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.agent.AgentExecutor"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.mcp.McpServerManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.mcp.ScopeManager"/>

        <!-- Infrastructure Services (PersistentStateComponent) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.infrastructure.storage.ConfigStorage"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.infrastructure.storage.SecureStorage"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.infrastructure.storage.SessionStorage"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.infrastructure.storage.StorageService"/>

        <!-- Feature Services (Phase 4+) -->
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.usage.UsageService"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.hook.HookManager"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.commit.CommitService"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.slash.command.SlashCommandRegistry"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.util.I18nService"/>
        <projectService
            serviceImplementation="com.github.xingzhewa.ccgui.application.config.LocaleConfigManager"/>

        <!-- Startup -->
        <postStartupActivity
            implementation="com.github.xingzhewa.ccgui.startup.MyProjectActivity"/>
    </extensions>

    <!-- Actions -->
    <actions>
        <action
            id="CCGUI.CodeExplain"
            class="com.github.xingzhewa.ccgui.action.CodeExplainAction"
            key="action.code.explain">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.CodeOptimize"
            class="com.github.xingzhewa.ccgui.action.CodeOptimizeAction"
            key="action.code.optimize">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.CodeComment"
            class="com.github.xingzhewa.ccgui.action.CodeCommentAction"
            key="action.code.comment">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.CodeTest"
            class="com.github.xingzhewa.ccgui.action.CodeTestAction"
            key="action.code.test">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.CodeRefactor"
            class="com.github.xingzhewa.ccgui.action.CodeRefactorAction"
            key="action.code.refactor">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.CodeBug"
            class="com.github.xingzhewa.ccgui.action.CodeBugAction"
            key="action.code.bug">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="CCGUI.AddToChat"
            class="com.github.xingzhewa.ccgui.action.AddToChatAction"
            key="action.add.to.chat">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
